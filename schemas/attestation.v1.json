{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recourseos.dev/schemas/attestation/v1",
  "title": "Recourse Attestation",
  "description": "Cryptographic proof of consequence evaluation before agent action",
  "type": "object",
  "required": ["input", "output", "evaluator", "timestamp", "key_id", "attestation_uri", "signature"],
  "additionalProperties": false,
  "properties": {
    "input": {
      "type": "object",
      "description": "The evaluation request (shell command, terraform plan, or MCP tool call)"
    },
    "output": {
      "type": "object",
      "description": "The evaluation result",
      "required": ["riskAssessment"],
      "properties": {
        "riskAssessment": {
          "type": "string",
          "enum": ["allow", "warn", "escalate", "block"],
          "description": "Final risk verdict"
        },
        "assessmentReason": {
          "type": "string",
          "description": "Human-readable explanation of the risk assessment"
        },
        "mutations": {
          "type": "array",
          "description": "List of detected state mutations",
          "items": { "$ref": "#/$defs/mutation" }
        },
        "summary": { "$ref": "#/$defs/summary" },
        "trace": { "$ref": "#/$defs/reasoningTrace" },
        "verification": { "$ref": "#/$defs/verificationInstructions" },
        "version": {
          "type": "string",
          "description": "Output schema version"
        }
      }
    },
    "evaluator": {
      "type": "string",
      "pattern": "^recourse:[a-z-]+:[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Evaluator identifier in format recourse:<type>:<semver>",
      "examples": ["recourse:blast-radius:1.0.0"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when evaluation was performed"
    },
    "key_id": {
      "type": "string",
      "description": "Identifier of the Ed25519 signing key",
      "examples": ["recourse-prod-1", "recourse-local-1"]
    },
    "attestation_uri": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://.+/\\.well-known/attestations/[a-f0-9]{32}\\.json$",
      "description": "Canonical URL where this attestation can be retrieved"
    },
    "signature": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "description": "Base64url-encoded Ed25519 signature (no padding)"
    }
  },
  "$defs": {
    "mutation": {
      "type": "object",
      "description": "A detected state mutation",
      "required": ["intent", "recoverability"],
      "properties": {
        "intent": {
          "type": "object",
          "required": ["action"],
          "properties": {
            "source": {
              "type": "string",
              "enum": ["terraform", "shell", "mcp"],
              "description": "Source type of the mutation"
            },
            "action": {
              "type": "string",
              "enum": ["create", "update", "delete", "replace", "unknown"],
              "description": "Type of mutation"
            },
            "target": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "properties": {
                    "service": { "type": "string" },
                    "type": { "type": "string" },
                    "id": { "type": "string" }
                  }
                }
              ],
              "description": "Target resource identifier"
            },
            "raw": {
              "type": "string",
              "description": "Original command or resource address"
            }
          }
        },
        "recoverability": {
          "type": "object",
          "required": ["tier", "label"],
          "properties": {
            "tier": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5,
              "description": "Recoverability tier (1=reversible, 5=needs-review)"
            },
            "label": {
              "type": "string",
              "enum": ["reversible", "recoverable-with-effort", "recoverable-from-backup", "unrecoverable", "needs-review"],
              "description": "Human-readable recoverability label"
            },
            "reasoning": {
              "type": "string",
              "description": "Explanation for the recoverability assessment"
            },
            "source": {
              "type": "string",
              "enum": ["handler", "classifier"],
              "description": "Whether assessment came from deterministic handler or classifier"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence score (1.0 for handlers, lower for classifier)"
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "dependencyImpact": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Resources that depend on this one"
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "totalMutations": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of mutations detected"
        },
        "worstRecoverability": {
          "type": "object",
          "properties": {
            "tier": { "type": "integer" },
            "label": { "type": "string" }
          }
        },
        "needsReview": {
          "type": "boolean",
          "description": "Whether human review is required"
        },
        "hasUnrecoverable": {
          "type": "boolean",
          "description": "Whether any unrecoverable mutations were detected"
        },
        "dependencyImpactCount": {
          "type": "integer",
          "description": "Total cascade impact count"
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["key", "present"],
      "properties": {
        "key": {
          "type": "string",
          "description": "Evidence identifier"
        },
        "value": {
          "description": "Evidence value (any type)"
        },
        "present": {
          "type": "boolean",
          "description": "Whether the evidence was found"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the evidence"
        }
      }
    },
    "reasoningTrace": {
      "type": "object",
      "description": "Step-by-step reasoning chain for the evaluation",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "description": "Ordered list of evaluation steps",
          "items": { "$ref": "#/$defs/traceStep" }
        },
        "duration_ms": {
          "type": "number",
          "description": "Total evaluation time in milliseconds"
        },
        "handlers_invoked": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of handler names that were invoked"
        },
        "state_sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sources of state used (terraform, aws-api, etc.)"
        }
      }
    },
    "traceStep": {
      "type": "object",
      "required": ["step", "action", "result"],
      "properties": {
        "step": {
          "type": "integer",
          "description": "Step number (1-indexed)"
        },
        "action": {
          "type": "string",
          "description": "What was done in this step",
          "examples": ["parse_input", "route_to_handler", "check_backup_config", "assess_recoverability"]
        },
        "target": {
          "type": "string",
          "description": "Resource or component this step operated on"
        },
        "result": {
          "type": "string",
          "description": "Outcome of this step"
        },
        "evidence_gathered": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" },
          "description": "Evidence collected during this step"
        },
        "decision": {
          "type": "string",
          "description": "Decision made based on this step (if any)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in this step's result"
        }
      }
    },
    "verificationInstructions": {
      "type": "object",
      "description": "Instructions for independently verifying this assessment",
      "properties": {
        "commands": {
          "type": "array",
          "description": "Commands a verifier can run to confirm the assessment",
          "items": {
            "type": "object",
            "required": ["description", "command"],
            "properties": {
              "description": {
                "type": "string",
                "description": "What this command checks"
              },
              "command": {
                "type": "string",
                "description": "The command to run"
              },
              "expected_pattern": {
                "type": "string",
                "description": "Regex pattern expected in output to confirm assessment"
              },
              "confirms": {
                "type": "string",
                "description": "What aspect of the assessment this confirms"
              }
            }
          }
        },
        "api_checks": {
          "type": "array",
          "description": "API calls a verifier can make",
          "items": {
            "type": "object",
            "required": ["service", "operation"],
            "properties": {
              "service": {
                "type": "string",
                "description": "AWS/GCP/Azure service name"
              },
              "operation": {
                "type": "string",
                "description": "API operation name"
              },
              "parameters": {
                "type": "object",
                "description": "Parameters for the API call"
              },
              "expected_result": {
                "type": "object",
                "description": "Expected result structure"
              }
            }
          }
        },
        "reproducibility": {
          "type": "string",
          "enum": ["deterministic", "state-dependent", "time-sensitive"],
          "description": "Whether this assessment can be exactly reproduced"
        },
        "state_snapshot": {
          "type": "object",
          "description": "Snapshot of relevant state at evaluation time",
          "properties": {
            "captured_at": {
              "type": "string",
              "format": "date-time"
            },
            "resources": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
